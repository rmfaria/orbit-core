    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@orbit/core-contracts": "workspace:*",
    "@orbit/engine": "workspace:*",
    "@orbit/storage-pg": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "pg": "^8.12.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "vitest": "^4.0.18"
  }
