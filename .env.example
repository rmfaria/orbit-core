# orbit-core — environment variables
# Copy to .env before running:  cp .env.example .env
# SPDX-License-Identifier: Apache-2.0

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the PostgreSQL database.
# Change this in production. Used to build DATABASE_URL internally.
POSTGRES_PASSWORD=postgres

# ── API authentication ────────────────────────────────────────────────────────
# Secret API key required on every request (X-Api-Key header or Authorization: Bearer).
# Leave empty to run without authentication (development only — NOT recommended in production).
# Connectors and the UI need this key to call the API.
ORBIT_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
# Host port the UI/nginx listens on.
ORBIT_PORT=80

# ── Logging ───────────────────────────────────────────────────────────────────
# API log level: trace | debug | info | warn | error
LOG_LEVEL=info
