{
  "name": "orbit-core",
  "private": true,
  "version": "1.3.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rimraf node_modules packages/*/node_modules",
    "format": "prettier -w .",
    "db:migrate": "pnpm --filter @orbit/storage-pg db:migrate",
    "api:dev": "pnpm --filter @orbit/api dev",
    "ui:dev": "pnpm --filter @orbit/ui dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
