# Wazuh (OpenSearch) alerts → orbit-core
# Install: cp this file to /etc/cron.d/openclaw-wazuh-orbitcore
# Secrets: ORBIT_API_KEY, OPENSEARCH_PASS

*/2 * * * * root \
  ORBIT_API_KEY=<ORBIT_API_KEY> \
  ORBIT_API=http://localhost:3000 \
  OPENSEARCH_URL=<YOUR_OPENSEARCH_URL> \
  OPENSEARCH_USER=admin \
  OPENSEARCH_PASS=<OPENSEARCH_PASS> \
  WAZUH_OS_INDEX_PATTERN=wazuh-alerts-4.x-* \
  WAZUH_ASSET_ID=wazuh:sec-ne \
  WINDOW_MINUTES=60 \
  TOP_N=10 \
  SPIKE_WINDOW_MINUTES=5 \
  SPIKE_GE10_THRESHOLD=25 \
  python3 /root/.openclaw/workspace/scripts/wazuh_orbitcore_connector.py \
  >/var/log/nagios4/wazuh_orbitcore_connector.log 2>&1
