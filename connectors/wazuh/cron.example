# Wazuh → orbit-core — cron examples
# Choose ONE approach depending on your deployment:

# ── OPTION A: Passive (file-based) ───────────────────────────────────────────
# Use when the connector runs on the SAME host as the Wazuh Manager.
# Reads /var/ossec/logs/alerts/alerts.json directly.
# MAX_BYTES_PER_RUN=52428800 (50MB) recommended for high-volume environments.
# BATCH_SIZE=100 to stay under the 1MB API payload limit for large Wazuh events.

* * * * * root \
  ORBIT_API=https://prod.example.com/orbit-core \
  ORBIT_API_KEY=<sua-chave> \
  WAZUH_ALERTS_JSON=/var/ossec/logs/alerts/alerts.json \
  STATE_PATH=/var/lib/orbit-core/wazuh-events.state.json \
  MAX_BYTES_PER_RUN=52428800 \
  BATCH_SIZE=100 \
  python3 /opt/orbit-core/connectors/wazuh/ship_events.py \
  >>/var/log/orbit-core/wazuh_shipper.log 2>&1

# ── OPTION B: Active (OpenSearch / Wazuh Indexer) ────────────────────────────
# Use when Wazuh Manager is on a DIFFERENT host with OpenSearch/Wazuh Indexer.
# NOTE: OpenSearch often listens on 127.0.0.1:9200 only — check with:
#   ss -tlnp | grep 9200
# If loopback only, use OPTION A (run on the Wazuh Manager host).

*/2 * * * * root \
  ORBIT_API=https://prod.example.com/orbit-core \
  ORBIT_API_KEY=<sua-chave> \
  OPENSEARCH_URL=https://wazuh-manager:9200 \
  OPENSEARCH_USER=admin \
  OPENSEARCH_PASS=admin \
  OPENSEARCH_VERIFY_TLS=false \
  WAZUH_OS_INDEX_PATTERN=wazuh-alerts-4.x-* \
  MIN_LEVEL=3 \
  STATE_PATH=/var/lib/orbit-core/wazuh-opensearch-events.state.json \
  python3 /opt/orbit-core/connectors/wazuh/ship_events_opensearch.py \
  >>/var/log/orbit-core/wazuh_os_shipper.log 2>&1

# ── OPTION C: Wazuh REST API (structured data) ──────────────────────────────
# Pulls agents, SCA, MITRE ATT&CK, syscollector, vulnerabilities, and manager
# stats from the Wazuh REST API. Complements OPTION A/B (which ship alerts).
# Run every 5 minutes.

*/5 * * * * root \
  WAZUH_API_URL=https://wazuh-manager:55000 \
  WAZUH_API_USER=wazuh-wui \
  WAZUH_API_PASS=<your-wazuh-api-password> \
  WAZUH_VERIFY_TLS=false \
  ORBIT_API=https://prod.example.com/orbit-core \
  ORBIT_API_KEY=<sua-chave> \
  SOURCE_ID=wazuh-api \
  python3 /opt/orbit-core/connectors/wazuh/ship_wazuh_api.py \
  >>/var/log/orbit-core/wazuh_api_shipper.log 2>&1
